<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="barista_bot">

<xacro:include filename="$(find barista_robot_description)/xacro/caster_wheel.xacro" />
<xacro:include filename="$(find barista_robot_description)/xacro/cup_holder_tray.xacro" />
<xacro:include filename="$(find barista_robot_description)/xacro/drive_wheel.xacro" />
<xacro:include filename="$(find barista_robot_description)/xacro/laser_scanner.xacro" />
<xacro:include filename="$(find barista_robot_description)/xacro/standoff_rod.xacro" />

<xacro:arg name="robot_name" default="barista_bot"/>
<xacro:arg name="include_laser" default="true"/>
<xacro:arg name="gazebo_color" default="Gazebo/White"/>
<xacro:arg name="color" default="White"/>

<xacro:property name="robot_name" value="$(arg robot_name)"/>
<xacro:property name="gazebo_color" value="$(arg gazebo_color)"/>
<xacro:property name="color" value="$(arg color)"/>
<xacro:property name="include_laser" value="$(arg include_laser)"/>

<material name="blue">
      <color rgba="0.0 0.0 1.0 1"/>
</material>

<material name="white">
      <color rgba="1 1 1 1"/>
</material>

<material name="black">
      <color rgba="0 0 0 1"/>
</material>

<material name="red">
    <color rgba="1.0 0.0 0.0 1"/>
</material>


<material name="green_light">
    <color rgba="0.0 1.0 0.0 1"/>
</material>

<!-- URDF Definition -->
<link name="base_link" />


<!--Main Body-->
<link name="main_body_link">
    <visual>
        <geometry>
            <cylinder length="0.155" radius="0.178" />
        </geometry>
        <material name="${color}" />
    </visual>

    <collision>
        <geometry>
          <cylinder length="0.155" radius="0.178"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00496154166666" ixy="0" ixz="0" iyy="0.00496154166666" iyz="0" izz="0.007921"/>
    </inertial>
</link>

<joint name="base_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.135" />
    <parent link="base_link" />
    <child link="main_body_link" />
</joint>

<gazebo reference="main_body_link">
    <material>${gazebo_color}</material>
</gazebo>


<!--Standoff Rods-->
<xacro:standoff_rod link_name="standoff_front_right_link" width="0.010" length="0.220" />
<xacro:standoff_rod link_name="standoff_back_right_link" width="0.010" length="0.220" />
<xacro:standoff_rod link_name="standoff_front_left_link" width="0.010" length="0.220" />
<xacro:standoff_rod link_name="standoff_back_left_link" width="0.010" length="0.220" />


<joint name="main_body_to_standoff_front_right_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.058 0.099 0.1875" />
    <parent link="main_body_link" />
    <child link="standoff_front_right_link" />
</joint>

<joint name="main_body_to_standoff_back_right_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.058 0.099 0.1875" />
    <parent link="main_body_link" />
    <child link="standoff_back_right_link" />
</joint>

<joint name="main_body_to_standoff_front_left_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.058 -0.099 0.1875" />
    <parent link="main_body_link" />
    <child link="standoff_front_left_link" />
</joint>

<joint name="main_body_to_standoff_back_left_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.058 -0.099 0.1875" />
    <parent link="main_body_link" />
    <child link="standoff_back_left_link" />
</joint>


<!--Drive Wheels-->
<xacro:drive_wheel link_name="right_wheel_link" wheel_radius="0.0352" wheel_width="0.0206" />
<xacro:drive_wheel link_name="left_wheel_link" wheel_radius="0.0352" wheel_width="0.0206" />

<joint name="main_body_to_right_wheel_link_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 -0.148 -.1" />
    <parent link="main_body_link" />
    <child link="right_wheel_link" />
    <axis xyz="0 1 0" />
</joint>

<joint name="main_body_to_left_wheel_link_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0.148 -0.1" />
    <parent link="main_body_link" />
    <child link="left_wheel_link" />
    <axis xyz="0 1 0" />
</joint>


<!--Caster Wheels-->
<xacro:caster_wheel position="front" />
<xacro:caster_wheel position="back" />

<joint name="main_body_to_front_caster_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.125 0 -0.1" />
    <parent link="main_body_link"/>
    <child link="front_caster_link"/>
</joint> 

<joint name="main_body_to_back_caster_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.125 0 -0.1" />
    <parent link="main_body_link"/>
    <child link="back_caster_link"/>
</joint>


<!--Cup Holder Tray-->
<xacro:cup_holder_tray gazebo_color="${gazebo_color}" color="${color}"/>


<joint name="main_body_to_cup_holder_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.3425" />
    <parent link="main_body_link" />
    <child link="cup_holder_link" />
</joint>


<!--PLUGINS-->

<!-- JOINT PUBLISHER -->
<gazebo>
<plugin name="barista_bot_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
    <ros>
        <namespace>/${robot_name}</namespace>
        <remapping>~/out:=joint_states</remapping>
    </ros>
    <update_rate>30</update_rate>

    <joint_name>main_body_to_right_wheel_link_joint</joint_name>
    <joint_name>main_body_to_left_wheel_link_joint</joint_name>

    
</plugin>
</gazebo>


<!-- Differential drive -->
<gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">
        <ros>
            <namespace>/${robot_name}</namespace>
        </ros>

        <!-- wheels -->
        <left_joint>main_body_to_left_wheel_link_joint</left_joint>
        <right_joint>main_body_to_right_wheel_link_joint</right_joint>

        <!-- kinematics -->
        <wheel_separation>0.296</wheel_separation>
        <wheel_diameter>0.0704</wheel_diameter>

        <!-- limits -->
        <max_wheel_torque>20.0</max_wheel_torque>
        <max_wheel_acceleration>2.0</max_wheel_acceleration>

        <!-- output -->
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>

        <odometry_frame>${robot_name}/odom</odometry_frame>
        <robot_base_frame>${robot_name}/base_link</robot_base_frame>

    </plugin>
</gazebo>



<!--Laser-->
<xacro:if value="${include_laser}">
    <xacro:laser_scanner />

    <joint name="laser_scan_link_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.128 0 0.0775"/>
        <parent link="main_body_link"/>
        <child link="laser_scan_link"/>
    </joint>

    <!-- Lidar Plugin -->
    <gazebo reference="laser_scan_link">
        <sensor name="sensor_ray" type="ray">
            <pose>0 0 0.34 0 0 0</pose>
            <ray>
            <scan>
                <horizontal>
                <samples>200</samples>
                <resolution>1.0</resolution>
                <min_angle>-3.14</min_angle>
                <max_angle>3.14</max_angle>
                </horizontal>
            </scan>
            <range>
                <min>0.1</min>
                <max>5.0</max>
            </range>
            </ray>
            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>100.0</update_rate>
            <plugin name="laser" filename="libgazebo_ros_ray_sensor.so">
            <ros>
                <namespace>/${robot_name}</namespace>
                <remapping>~/out:=scan</remapping>
            </ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            </plugin>
        </sensor>
    </gazebo>
</xacro:if>

</robot>