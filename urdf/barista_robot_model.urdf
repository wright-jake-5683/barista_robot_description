<?xml version="1.0"?>
<robot name="barista_bot">

<material name="blue">
      <color rgba="0.0 0.0 1.0 1"/>
</material>

<material name="white">
      <color rgba="1 1 1 1"/>
</material>

<material name="black">
      <color rgba="0 0 0 1"/>
</material>

<material name="red">
    <color rgba="1.0 0.0 0.0 1"/>
</material>


<material name="green_light">
    <color rgba="0.0 1.0 0.0 1"/>
</material>


<link name="base_link" />

<!--Main Body-->
<link name="main_body_link">
    <visual>
        <geometry>
            <cylinder length="0.155" radius="0.178" />
        </geometry>
        <material name="blue" />
    </visual>

    <collision>
        <geometry>
          <cylinder length="0.155" radius="0.178"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00496154166666" ixy="0" ixz="0" iyy="0.00496154166666" iyz="0" izz="0.007921"/>
    </inertial>
</link>

<joint name="base_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.135" />
    <parent link="base_link" />
    <child link="main_body_link" />
</joint>

<gazebo reference="main_body_link">
    <material>Gazebo/Blue</material>
</gazebo>

<!--Standoff Rods-->
<link name="standoff_front_right_link">
    <visual>
        <geometry>
            <cylinder length=".220" radius="0.010" />
        </geometry>
        <material name="white"/>
    </visual>

    <collision>
        <geometry>
          <cylinder length="0.220" radius="0.010"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00020291666666" ixy="0" ixz="0" iyy="0.00020291666666" iyz="0" izz="0.0000025"/>
    </inertial>
</link>

<joint name="main_body_to_standoff_front_right_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.058 0.099 0.1875" />
    <parent link="main_body_link" />
    <child link="standoff_front_right_link" />
</joint>

<gazebo reference="standoff_front_right_link">
    <material>Gazebo/White</material>
</gazebo>

<link name="standoff_back_right_link">
    <visual>
        <geometry>
            <cylinder length=".220" radius="0.010" />
        </geometry>
        <material name="white"/>
    </visual>

    <collision>
        <geometry>
          <cylinder length="0.220" radius="0.010"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00020291666666" ixy="0" ixz="0" iyy="0.00020291666666" iyz="0" izz="0.0000025"/>
    </inertial>
</link>

<joint name="main_body_to_standoff_back_right_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.058 0.099 0.1875" />
    <parent link="main_body_link" />
    <child link="standoff_back_right_link" />
</joint>

<gazebo reference="standoff_back_right_link">
    <material>Gazebo/White</material>
</gazebo>

<link name="standoff_front_left_link">
    <visual>
        <geometry>
            <cylinder length=".220" radius="0.010" />
        </geometry>
        <material name="white"/>
    </visual>

    <collision>
        <geometry>
          <cylinder length="0.220" radius="0.010"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00020291666666" ixy="0" ixz="0" iyy="0.00020291666666" iyz="0" izz="0.0000025"/>
    </inertial>
</link>

<joint name="main_body_to_standoff_front_left_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.058 -0.099 0.1875" />
    <parent link="main_body_link" />
    <child link="standoff_front_left_link" />
</joint>

<gazebo reference="standoff_front_left_link">
    <material>Gazebo/White</material>
</gazebo>

<link name="standoff_back_left_link">
    <visual>
        <geometry>
            <cylinder length=".220" radius="0.010" />
        </geometry>
        <material name="white"/>
    </visual>

    <collision>
        <geometry>
          <cylinder length="0.220" radius="0.010"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00020291666666" ixy="0" ixz="0" iyy="0.00020291666666" iyz="0" izz="0.0000025"/>
    </inertial>
</link>

<joint name="main_body_to_standoff_back_left_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.058 -0.099 0.1875" />
    <parent link="main_body_link" />
    <child link="standoff_back_left_link" />
</joint>

<gazebo reference="standoff_back_left_link">
    <material>Gazebo/White</material>
</gazebo>

<!--Cup Holder Tray-->
<link name="cup_holder_link">
    <visual>
        <geometry>
            <cylinder length=".090" radius="0.160" />
        </geometry>
        <material name="blue"/>
    </visual>

    <collision>
        <geometry>
          <cylinder length="0.090" radius="0.160"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00035375" ixy="0" ixz="0" iyy="0.00035375" iyz="0" izz="0.00064"/>
    </inertial>
</link>

<joint name="main_body_to_cup_holder_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.3425" />
    <parent link="main_body_link" />
    <child link="cup_holder_link" />
</joint>

<gazebo reference="cup_holder_link">
    <material>Gazebo/Blue</material>
</gazebo>

<!--Wheels-->
<link name="right_wheel_link">
    <visual>
        <origin rpy="0 1.5707 1.5707" xyz ="0 0 0"/>
        <geometry>
            <cylinder length=".0206" radius="0.0352" />
        </geometry>
        <material name="black"/>
    </visual>

    <collision>
        <origin rpy="0 1.5707 1.5707" xyz ="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.340194"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx=".00011740888726" ixy="0" ixz="0" iyy=".00011740888726" iyz="0" izz=".00021075698688"/>
    </inertial>
</link>

<gazebo reference="right_wheel_link">
    <kp>10000000</kp>
    <kd>100</kd>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <material>Gazebo/Black</material>
</gazebo>

<joint name="main_body_to_right_wheel_link_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 -0.148 -.1" />
    <parent link="main_body_link" />
    <child link="right_wheel_link" />
    <axis xyz="0 1 0" />
    <limit effort="10000" velocity="1000"/>
    <dynamics damping="1.0" friction="1.0"/>
</joint>


<link name="left_wheel_link">
    <visual>
        <origin rpy="0 1.5707 1.5707" xyz ="0 0 0"/>
        <geometry>
            <cylinder length=".0206" radius="0.0352" />
        </geometry>
        <material name="black"/>
    </visual>

    <collision>
        <origin rpy="0 1.5707 1.5707" xyz ="0 0 0"/>
        <geometry>
          <cylinder length="0.0206" radius="0.0352"/>
        </geometry>
    </collision>

    <inertial>
      <mass value="0.340194"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx=".00011740888726" ixy="0" ixz="0" iyy=".00011740888726" iyz="0" izz=".00021075698688"/>
    </inertial>
</link>

<gazebo reference="left_wheel_link">
    <kp>10000000</kp>
    <kd>100</kd>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <material>Gazebo/Black</material>
</gazebo>

<joint name="main_body_to_left_wheel_link_joint" type="continuous">
    <origin rpy="0 0 0" xyz="0 0.148 -0.1" />
    <parent link="main_body_link" />
    <child link="left_wheel_link" />
    <axis xyz="0 1 0" />
    <limit effort="10000" velocity="1000"/>
    <dynamics damping="1.0" friction="1.0"/>
</joint>

<!--Caster Wheel Front-->
<link name="front_caster_link">
    <visual>
        <geometry>
            <sphere radius="0.0352"/>
        </geometry>
        <material name="white"/>
    </visual>
    <collision>
        <geometry>
            <sphere radius="0.0352"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.01"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.00000495616" ixy="0" ixz="0" iyy="0.00000495616" iyz="0" izz="0.00000495616"/>
    </inertial>
</link>

<joint name="main_body_to_front_caster_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.125 0 -0.1"/>
    <parent link="main_body_link"/>
    <child link="front_caster_link"/>
</joint>

<gazebo reference="front_caster_link">
    <kp>1000000</kp>
    <kd>100</kd>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/White</material>
</gazebo>

<!--Caster Wheel Back-->
<link name="back_caster_link">
    <visual>
        <geometry>
            <sphere radius="0.0352"/>
        </geometry>
        <material name="white"/>
    </visual>
    <collision>
        <geometry>
            <sphere radius="0.0352"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.01"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.00000495616" ixy="0" ixz="0" iyy="0.00000495616" iyz="0" izz="0.00000495616"/>
    </inertial>
</link>

<joint name="main_body_to_back_caster_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.125 0 -0.1"/>
    <parent link="main_body_link"/>
    <child link="back_caster_link"/>
</joint>

<gazebo reference="back_caster_link">
    <kp>1000000</kp>
    <kd>100</kd>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/White</material>
</gazebo>


<!--Laser-->
 <link name="laser_scan_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://barista_robot_description/meshes/hokuyo_urg_04lx.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </visual>

    <collision>
        <geometry>
            <box size="0.05 0.05 0.05"/>
        </geometry>
    </collision>

    <inertial>
        <mass value="0.113398"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.000047249166666" ixy="0" ixz="0" iyy="0.000047249166666" iyz="0" izz="0.000047249166666"/>
    </inertial>

</link>

<joint name="laser_scan_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.128 0 0.0775"/>
    <parent link="main_body_link"/>
    <child link="laser_scan_link"/>
</joint>

<link name="laser_scan_frame" />

<joint name="laser_scan_frame_to_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 .055" />
    <parent link="laser_scan_link" />
    <child link="laser_scan_frame" />
</joint>


<!--PLUGINS-->

<!-- JOINT PUBLISHER -->
<gazebo>
    <plugin name="barista_bot_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
        <ros>
            <remapping>~/out:=joint_states</remapping>
        </ros>
        <update_rate>30</update_rate>

        <joint_name>main_body_to_right_wheel_link_joint</joint_name>
        <joint_name>main_body_to_left_wheel_link_joint</joint_name>

    </plugin>
</gazebo>


<!-- Differential drive -->
<gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">

        <!-- wheels -->
        <left_joint>main_body_to_left_wheel_link_joint</left_joint>
        <right_joint>main_body_to_right_wheel_link_joint</right_joint>

        <!-- kinematics -->
        <wheel_separation>0.296</wheel_separation>
        <wheel_diameter>0.0704</wheel_diameter>

        <!-- limits -->
        <max_wheel_torque>100.0</max_wheel_torque>
        <max_wheel_acceleration>2.0</max_wheel_acceleration>

        <!-- output -->
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>

        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>

    </plugin>
</gazebo>

<!-- Lidar Plugin -->
<gazebo reference="laser_scan_frame">
    <material>Gazebo/DarkGrey</material>
    <sensor name="sensor_ray" type="ray">
        <pose> 0 0 0 0 0 0</pose>
        <ray>
          <scan>
            <horizontal>
              <samples>200</samples>
              <resolution>1.0</resolution>
              <min_angle>-3.14</min_angle>
              <max_angle>3.14</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.1</min>
            <max>5.0</max>
          </range>
        </ray>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>100.0</update_rate>
        <plugin name="laser" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/barista_bot</namespace>
            <remapping>~/out:=/scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
        </plugin>
    </sensor>
</gazebo>



</robot>